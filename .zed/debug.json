// Project-local debug tasks
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
  {
    "label": "Debug Current File (Dart)",
    "adapter": "Dart",
    "type": "dart",
    "request": "launch",
    "cwd": "$ZED_DIRNAME",
    "program": "$ZED_FILE",
  },
  {
    "label": "Flutter Current File (Dart)",
    "adapter": "Dart",
    "type": "flutter",
    "request": "launch",
    "cwd": "$ZED_DIRNAME",
    "program": "$ZED_FILE",
  },
]
